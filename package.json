{
  "name": "jupyterlab-save-py",
  "version": "0.1.0",
  "description": "Save the active JupyterLab notebook as a sibling Python script.",
  "keywords": [
    "jupyter",
    "jupyterlab",
    "jupyterlab-extension",
    "notebook",
    "python"
  ],
  "homepage": "https://github.com/mihnea/jupyterlab-save-py",
  "bugs": {
    "url": "https://github.com/mihnea/jupyterlab-save-py/issues"
  },
  "license": "MIT",
  "author": "jupyterlab-save-py contributors",
  "files": [
    "lib/**/*.{js,js.map,d.ts}",
    "schema/*.json",
    "style/**/*.css"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "style": "style/index.css",
  "sideEffects": [
    "style/*.css"
  ],
  "scripts": {
    "build": "jlpm build:lib && jlpm build:labextension:dev",
    "build:prod": "jlpm clean && jlpm build:lib && jlpm build:labextension",
    "build:labextension": "jupyter labextension build .",
    "build:labextension:dev": "jupyter labextension build --development True .",
    "build:lib": "tsc",
    "clean": "jlpm clean:lib && jlpm clean:labextension",
    "clean:labextension": "rimraf jupyterlab_save_py/labextension",
    "clean:lib": "rimraf lib tsconfig.tsbuildinfo",
    "lint": "jlpm prettier:check",
    "prettier": "prettier --write .",
    "prettier:check": "prettier --check .",
    "watch": "run-p watch:src watch:labextension",
    "watch:labextension": "jupyter labextension watch .",
    "watch:src": "tsc -w"
  },
  "dependencies": {
    "@jupyterlab/application": "^4.0.0",
    "@jupyterlab/apputils": "^4.0.0",
    "@jupyterlab/coreutils": "^6.0.0",
    "@jupyterlab/nbformat": "^4.0.0",
    "@jupyterlab/notebook": "^4.0.0",
    "@jupyterlab/services": "^7.0.0",
    "@jupyterlab/settingregistry": "^4.0.0",
    "@lumino/disposable": "^2.0.0",
    "@lumino/widgets": "^2.0.0"
  },
  "devDependencies": {
    "@jupyterlab/builder": "^4.0.0",
    "@types/json-schema": "^7.0.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "typescript": "~6.0.2"
  },
  "jupyterlab": {
    "extension": true,
    "outputDir": "jupyterlab_save_py/labextension",
    "schemaDir": "schema"
  },
  "publishConfig": {
    "access": "public"
  }
}
